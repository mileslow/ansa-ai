rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stores/{storeId} {
      allow read: if true;
      allow write: if true;
    }
    match /benefitsCompanies/{companyId} {
      allow read, write: if true;
      match /{document=**} { allow read, write: if true; }
    }
  }
}
